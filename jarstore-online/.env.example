# ── GitHub OAuth App ─────────────────────────────────────────────────────────
# https://github.com/settings/developers → New OAuth App
# Homepage URL:           https://your-app.vercel.app
# Authorization callback: https://your-app.vercel.app/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=random_string_at_least_32_characters

# ── Supabase (used only in serverless APIs) ───────────────────────────────────
# https://supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...      # service_role key (NOT the anon key!)

# ── App URL ───────────────────────────────────────────────────────────────────
# Development: http://localhost:5173
# Production: https://your-app.vercel.app
APP_URL=http://localhost:5173

# ── Frontend Vite (VITE_ prefix required) ─────────────────────────────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...    # anon/public key
VITE_APP_URL=http://localhost:5173
